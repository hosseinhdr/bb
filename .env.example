# Get these from https://my.telegram.org  ->  API development tools
API_ID=1234567
API_HASH=your_api_hash_here

# Your phone number in international format, e.g. +989123456789
PHONE=+10000000000

# Name of the Telethon session file (created on first login).
# Telethon stores it as "<SESSION_NAME>.session" in the current directory.
SESSION_NAME=userbot

# Optional: full path to the session file (overrides SESSION_NAME).
# Use this to keep one shared session regardless of where you run the bot from.
# SESSION_PATH=/Users/you/secrets/userbot.session
